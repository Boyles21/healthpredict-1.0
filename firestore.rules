rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && (request.auth.token.email.lower() == 'boluajisebutu45000@gmail.com' || request.auth.token.email.lower() == 'anochieglory1@gmail.com')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.uid is string 
        && data.uid.size() <= 128
        && data.fullName is string 
        && data.fullName.size() <= 200
        && data.email is string 
        && data.email.size() <= 200
        && (data.createdAt is timestamp || data.createdAt is map)
        && (data.lastLogin is timestamp || data.lastLogin is map)
        && (!('role' in data) || (data.role is string && data.role.size() <= 20))
        && (!('disabled' in data) || data.disabled is bool);
    }

    function isValidProfile(data) {
      return data.uid is string
        && data.uid.size() <= 128
        && data.fullName is string
        && data.fullName.size() <= 200
        && data.email is string
        && data.email.size() <= 200
        && data.location is string
        && data.location.size() <= 500
        && data.ethnicity is string
        && data.ethnicity.size() <= 500
        && data.bloodType is string
        && data.bloodType.size() <= 20
        && data.allergies is string
        && data.allergies.size() <= 1000
        && data.chronicConditions is string
        && data.chronicConditions.size() <= 1000
        && data.medications is string
        && data.medications.size() <= 1000
        && data.updatedAt is timestamp;
    }

    function isValidAssessment(data) {
      return data.uid is string
        && data.uid.size() <= 128
        && data.age is int
        && data.age >= 12
        && data.age <= 60
        && (data.weight is int || data.weight is float)
        && data.weight >= 30.0
        && data.weight <= 200.0
        && (data.height is int || data.height is float)
        && data.height >= 100.0
        && data.height <= 220.0
        && data.cycleRegularity is string
        && data.cycleRegularity.size() <= 50
        && data.cycleLength is int
        && data.cycleLength >= 1
        && data.cycleLength <= 100
        && data.weightGain is bool
        && data.hairGrowth is bool
        && data.hairLoss is bool
        && data.acne is bool
        && data.skinDarkening is bool
        && data.fastFood is bool
        && data.exercise is bool
        && data.pelvicPain is bool
        && data.fatigue is bool
        && (data.predictionPercentage is int || data.predictionPercentage is float)
        && data.predictionPercentage >= 0.0
        && data.predictionPercentage <= 100.0
        && data.riskCategory is string
        && data.riskCategory.size() <= 50
        && data.recommendations is list
        && data.recommendations.size() <= 50
        && data.createdAt is timestamp;
    }

    // 1. Users Collection
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().lastLogin == request.time
        && (!('role' in incoming()) || incoming().role == "user" || ('email' in request.auth.token && (request.auth.token.email.lower() == "boluajisebutu45000@gmail.com" || request.auth.token.email.lower() == "anochieglory1@gmail.com")));
        
      allow update: if (isOwner(uid)
        && isValidUser(incoming())
        && (!('uid' in existing()) || incoming().uid == existing().uid)
        && (!('email' in existing()) || incoming().email == existing().email)
        && (!('createdAt' in existing()) || incoming().createdAt == existing().createdAt)
        && incoming().lastLogin == request.time
        && (!('role' in incoming()) || !('role' in existing()) || incoming().role == existing().role)
        && (!('disabled' in incoming()) || !('disabled' in existing()) || incoming().disabled == existing().disabled))
        || isAdmin();

      allow delete: if isAdmin();
    }

    // 2. Profiles Collection
    match /profiles/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid)
        && isValidProfile(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if (isOwner(uid)
        && isValidProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().updatedAt == request.time)
        || isAdmin();

      allow delete: if isAdmin();
    }

    // 3. Assessments Collection
    match /assessments/{assessmentId} {
      allow get: if (isSignedIn() && resource.data.uid == request.auth.uid) || isAdmin();
      allow list: if (isSignedIn() && resource.data.uid == request.auth.uid) || isAdmin();
      
      allow create: if isSignedIn()
        && incoming().uid == request.auth.uid
        && isValidAssessment(incoming())
        && incoming().createdAt == request.time;
        
      allow update, delete: if isAdmin();
    }

    // 4. Settings Collection
    match /settings/{documentId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin()
        && isValidId(documentId)
        && (incoming().pcosHigh is int || incoming().pcosHigh is float)
        && (incoming().pcosMod is int || incoming().pcosMod is float)
        && (incoming().fibroidHigh is int || incoming().fibroidHigh is float)
        && (incoming().fibroidMod is int || incoming().fibroidMod is float)
        && (incoming().updatedAt is timestamp || incoming().updatedAt is map);
      allow delete: if isAdmin();
    }
  }
}
